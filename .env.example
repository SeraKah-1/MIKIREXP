# ================================
# MIKIR APP - Environment Variables
# ================================
# Rename file ini ke .env untuk local dev
# Atau tambahkan di Vercel Environment Variables

# --- Vertex AI (Primary / Utama) ---
# Set 'true' untuk menggunakan Vertex AI sebagai provider utama
VITE_USE_VERTEX_AI=true
# Google Cloud Project ID (wajib jika VITE_USE_VERTEX_AI=true)
VITE_GCP_PROJECT_ID=
# Google Cloud Region (default: us-central1)
VITE_GCP_LOCATION=us-central1
VITE_VERTEX_API_KEY=
VITE_AI_BACKEND_URL=

# --- Gemini API Key ---
# Digunakan untuk kedua mode (Vertex AI & Google AI Studio)
# Dapatkan di: https://aistudio.google.com/
GEMINI_API_KEY=

# --- Google AI Studio (Fallback / Cadangan) ---
# Jika VITE_USE_VERTEX_AI=false, app akan menggunakan Google AI Studio
# dengan API Key di atas secara langsung (tanpa Vertex AI)

# --- Firebase ---
VITE_FIREBASE_API_KEY=
VITE_EXTERNAL_FIREBASE_API_KEY=
VITE_EXTERNAL_FIREBASE_AUTH_DOMAIN=
VITE_EXTERNAL_FIREBASE_STORAGE_BUCKET=
VITE_EXTERNAL_FIREBASE_MESSAGING_SENDER_ID=
VITE_EXTERNAL_FIREBASE_APP_ID=